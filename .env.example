# === БАЗА ДАНИХ ===
POSTGRES_DB=cardforge
POSTGRES_USER=cardforge
POSTGRES_PASSWORD=змініть_на_надійний_пароль

# === DJANGO ===
SECRET_KEY=замініть-на-довгий-випадковий-рядок-мінімум-50-символів
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# === GOOGLE OAUTH ===
# Отримати на: https://console.cloud.google.com/
# 1. Створіть проєкт → APIs & Services → Credentials
# 2. OAuth 2.0 Client ID → Web application
# 3. Authorized redirect URIs: http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=ваш_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ваш_google_client_secret

# === ANTHROPIC API ===
# Отримати на: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-ваш_ключ

# === FRONTEND ===
REACT_APP_API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# === RENDER + NEON ===
# DATABASE_URL має бути Neon Postgres connection string з sslmode=require.
# Приклад Render URL, якщо назви сервісів не змінювались:
# FRONTEND_URL=https://cardforge-web.onrender.com
# CORS_ALLOWED_ORIGINS=https://cardforge-web.onrender.com
# CSRF_TRUSTED_ORIGINS=https://cardforge-web.onrender.com
# REACT_APP_API_URL=https://cardforge-api.onrender.com/api
